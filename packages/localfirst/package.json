{
  "name": "convex-localfirst",
  "version": "0.2.1",
  "description": "Local-first collections for Convex — one install: optimistic, offline-capable React hooks with Convex as the source of truth.",
  "license": "MIT",
  "keywords": [
    "convex",
    "local-first",
    "offline-first",
    "sync",
    "react"
  ],
  "author": "Fanzzzd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fanzzzd/convex-localfirst.git",
    "directory": "packages/localfirst"
  },
  "homepage": "https://github.com/Fanzzzd/convex-localfirst#readme",
  "bugs": {
    "url": "https://github.com/Fanzzzd/convex-localfirst/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./component/convex.config.js": "./component/convex/convex.config.ts",
    "./component/convex.config": "./component/convex/convex.config.ts"
  },
  "files": [
    "dist",
    "component"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"const fs=require('node:fs');fs.rmSync('component',{recursive:true,force:true});fs.cpSync('../component/convex','component/convex',{recursive:true})\" && tsc -p tsconfig.json --noEmit false --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@convex-localfirst/core": "workspace:*",
    "@convex-localfirst/react": "workspace:*",
    "@convex-localfirst/server": "workspace:*"
  },
  "peerDependencies": {
    "convex": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}