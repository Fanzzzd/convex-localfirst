{
  "name": "@convex-localfirst/react",
  "version": "0.2.0",
  "description": "Convex-compatible React hooks (useQuery/useMutation/useSyncStatus) for local-first, offline-capable apps.",
  "license": "MIT",
  "keywords": [
    "convex",
    "local-first",
    "offline",
    "react",
    "hooks"
  ],
  "author": "Fanzzzd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fanzzzd/convex-localfirst.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Fanzzzd/convex-localfirst#readme",
  "bugs": {
    "url": "https://github.com/Fanzzzd/convex-localfirst/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shadow": {
      "types": "./dist/shadow.d.ts",
      "import": "./dist/shadow.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit false --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "convex": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@convex-localfirst/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
