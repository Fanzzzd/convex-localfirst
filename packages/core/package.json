{
  "name": "@convex-localfirst/core",
  "version": "0.2.0",
  "description": "Local-first engine, store contract, and sync protocol for Convex — optimistic writes, offline cache, rebase/replay.",
  "license": "MIT",
  "keywords": [
    "convex",
    "local-first",
    "offline",
    "sync",
    "optimistic"
  ],
  "author": "Fanzzzd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fanzzzd/convex-localfirst.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Fanzzzd/convex-localfirst#readme",
  "bugs": {
    "url": "https://github.com/Fanzzzd/convex-localfirst/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit false --emitDeclarationOnly false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
