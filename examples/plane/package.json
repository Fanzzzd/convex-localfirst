{
  "name": "plane-localfirst",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "mu:whoami": "node multiuser-harness/whoami-probe.mjs",
    "mu:seed": "node multiuser-harness/seed.mjs",
    "mu:proof": "node multiuser-harness/multiuser-proof.mjs",
    "mu:setmerge": "node multiuser-harness/setmerge-proof.mjs",
    "mu:all": "node multiuser-harness/whoami-probe.mjs && node multiuser-harness/seed.mjs && node multiuser-harness/multiuser-proof.mjs && node multiuser-harness/setmerge-proof.mjs",
    "backend": "./local-backend/serve.sh",
    "backend:deploy": "./local-backend/deploy.sh",
    "inc:proof": "node local-backend/incremental-proof.mjs"
  },
  "dependencies": {
    "convex": ">=1.0.0",
    "convex-localfirst": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "latest"
  }
}
